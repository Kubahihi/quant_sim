# Copy this file to .streamlit/secrets.toml and set your real key.
# The app resolves key in this order:
# 1) st.secrets["GROQ_API_KEY"]
# 2) environment variable GROQ_API_KEY

GROQ_API_KEY = "gsk_your_groq_api_key_here"

# Shared online database (Turso / libSQL).
# Create these values in Turso and add the real values only to your local
# secrets.toml or to Streamlit Cloud's Secrets settings.
TURSO_DATABASE_URL = "libsql://your-database.turso.io"
TURSO_AUTH_TOKEN = "your-turso-auth-token"

# Login credentials for the Wharton Cockpit. Set a distinct strong password
# for every account in Streamlit Cloud; do not commit the live values.
[wharton_users]
Jakub = "replace-with-a-strong-password"
"Matěj" = "replace-with-a-strong-password"
Martin = "replace-with-a-strong-password"
"Lukáš" = "replace-with-a-strong-password"
Janek = "replace-with-a-strong-password"
Matfyz_Genius = "replace-with-a-strong-password"

# Persistent file storage for production.
[storage]
STORAGE_BACKEND = "r2"
R2_BUCKET = "your-r2-bucket"
R2_ENDPOINT_URL = "https://your-account-id.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID = "your-r2-access-key-id"
R2_SECRET_ACCESS_KEY = "your-r2-secret-access-key"
R2_REGION = "auto"
